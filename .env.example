# ---------- PostgreSQL ----------
POSTGRES_DB=tenders
POSTGRES_USER=tenders
POSTGRES_PASSWORD=tenders
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Используется backend и Alembic.
DATABASE_URL=postgresql+asyncpg://tenders:tenders@db:5432/tenders

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Секрет для подписи JWT. ОБЯЗАТЕЛЬНО заменить в проде.
JWT_SECRET=change-me-in-production-please
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14
# Shared secret для внутреннего API (бот ↔ backend).
INTERNAL_API_TOKEN=change-me-internal-token
# CORS для фронта.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ---------- Scheduler ----------
PARSER_INTERVAL_MINUTES=30
# ВНИМАНИЕ: источник "efrsb" временно заморожен (Qrator блокирует HTTP-доступ
# к публичному API bankrot.fedresurs.ru). Код источника оставлен, включение —
# после восстановления доступа или добавления headless-обхода.
PARSER_SOURCES=torgi_gov
DIGEST_CHECK_INTERVAL_MINUTES=1

# ---------- Telegram bot ----------
# Получить в @BotFather.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_REAL_BOT_TOKEN
TELEGRAM_BOT_USERNAME=your_bot_username
# URL backend для бота (внутри docker-compose).
BACKEND_INTERNAL_URL=http://backend:8000

# ---------- Admin ----------
# Bootstrap-админ создаётся при первом старте backend, если в БД нет ни одного
# админа. Идемпотентно: при повторном старте ничего не меняется.
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_EMAIL=admin@tenders.app
ADMIN_PASSWORD=admin12345
# Размер кольцевого буфера live-логов (записей).
ADMIN_LOG_BUFFER_SIZE=2000
# Сколько секунд без heartbeat считаем бот offline.
ADMIN_BOT_OFFLINE_THRESHOLD_SECONDS=120

# ---------- Frontend ----------
# Публичный URL backend (с точки зрения браузера).
FRONTEND_API_BASE_URL=http://localhost:8000/api
